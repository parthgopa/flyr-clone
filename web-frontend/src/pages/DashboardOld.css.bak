.dashboard-container {
  width: 100%;
}

.dashboard-title {
  font-size: var(--font-size-3xl);
  font-weight: 700;
  color: var(--color-black);
  margin-bottom: var(--spacing-xs);
}

.dashboard-subtitle {
  font-size: var(--font-size-base);
  color: var(--color-secondary);
}

.dashboard-section {
  margin-bottom: var(--spacing-2xl);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-black);
  margin-bottom: var(--spacing-lg);
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--spacing-lg);
}

.stats-grid-2 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--spacing-lg);
}

.stat-card {
  text-align: center;
}

.stat-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--spacing-md);
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-black);
  margin-bottom: var(--spacing-xs);
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

/* Token Stats */
.token-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: var(--spacing-lg);
  border-bottom: 1px solid var(--color-border);
}

.token-stat {
  text-align: center;
}

.token-value {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-black);
}

.token-label {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  margin-top: var(--spacing-xs);
}

.token-divider {
  width: 1px;
  height: 40px;
  background: var(--color-border);
}

.token-breakdown {
  display: flex;
  justify-content: center;
  gap: var(--spacing-xl);
  padding-top: var(--spacing-lg);
}

.token-small {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

/* Settings */
.settings-grid {
  display: flex;
  flex-direction: column;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
}

.setting-label {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

.setting-input {
  width: 100px;
  padding: 8px 12px;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  font-weight: 700;
  text-align: center;
  color: var(--color-black);
}

.setting-input:focus {
  outline: none;
  border-color: var(--color-accent);
}

.setting-divider {
  height: 1px;
  background: var(--color-border);
}

/* Actions Grid */
.actions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--spacing-lg);
}

.action-card {
  cursor: pointer;
}

.action-title {
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--color-black);
  margin-bottom: var(--spacing-xs);
}

.action-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}
